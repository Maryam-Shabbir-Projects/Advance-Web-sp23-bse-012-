<%- include('partials/header') %>

<!-- Hero Section -->
<div style="position: relative; text-align: center; color: white; height: 60vh; background: url('/images/blog-hero.jpg') center/cover no-repeat;">
  <div style="position: absolute; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.5);"></div>
  <div style="position: relative; height:100%; display: flex; flex-direction: column; justify-content: center; align-items: center;">
    <h1 style="font-size: 3rem; font-weight: bold; margin-bottom: 20px;">Welcome to My Blog</h1>
    <p style="font-size: 1.2rem; margin-bottom: 30px;">Discover amazing posts, tips, and stories from our community.</p>
    <a href="/posts" style="padding: 12px 25px; background-color: #0d6efd; color: white; text-decoration: none; border-radius: 5px; font-weight: bold;">Explore Posts</a>
  </div>
</div>

<!-- Latest Posts -->
<div style="max-width: 1200px; margin: 50px auto;">
  <h2 style="text-align: center; margin-bottom: 30px;">Latest Posts</h2>
  <div style="display: flex; flex-wrap: wrap; gap: 20px; justify-content: center;">
    <% if (posts && posts.length > 0) { %>
      <% posts.slice(0, 6).forEach(post => { %>
        <div style="flex: 1 1 300px; max-width: 350px; background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.1); display: flex; flex-direction: column;">
          <% if(post.image){ %>
            <img src="/uploads/<%= post.image %>" alt="<%= post.title %>" style="width: 100%; height: 200px; object-fit: cover;">
          <% } else { %>
            <img src="/images/default-post.jpg" alt="<%= post.title %>" style="width: 100%; height: 200px; object-fit: cover;">
          <% } %>
          <div style="padding: 15px; flex: 1; display: flex; flex-direction: column;">
            <h3 style="font-size: 1.3rem; margin-bottom: 10px;"><%= post.title %></h3>
            <p style="flex:1; color: #555; font-size: 0.95rem;"><%= post.content.substring(0, 120) %>...</p>
            <a href="/posts/<%= post._id %>" style="margin-top: 10px; align-self: flex-start; padding: 6px 12px; background-color: #0d6efd; color:white; text-decoration:none; border-radius:4px; font-size:0.9rem;">Read More</a>
          </div>
          <div style="padding: 10px 15px; font-size: 0.8rem; color:#888; display:flex; justify-content: space-between; background:#f8f9fa;">
            <span>By <%= post.author ? post.author.username : "Unknown" %></span>
            <span><%= new Date(post.createdAt).toLocaleDateString() %></span>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p style="text-align: center; color: #777; font-size: 1rem;">No posts yet. Be the first to create one!</p>
    <% } %>
  </div>
</div>

<!-- Call to Action -->
<div style="background-color: #0d6efd; color:white; padding: 50px 20px; text-align: center;">
  <h2 style="margin-bottom: 15px;">Want to share your story?</h2>
  <p style="margin-bottom: 25px;">Join our community and write your own post today!</p>
  <a href="/posts/create" style="padding: 12px 25px; background-color: white; color:#0d6efd; text-decoration:none; border-radius:5px; font-weight:bold;">Create Post</a>
</div>

<%- include('partials/footer') %>