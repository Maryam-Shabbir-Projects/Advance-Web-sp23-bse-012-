<!-- views/partials/header.ejs -->
<nav style="width:100%; background-color:#f8f9fa; padding:10px 20px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
  <div style="max-width:1200px; margin:0 auto; display:flex; justify-content:space-between; align-items:center;">
    
    <!-- Brand -->
    <a href="/" style="font-size:1.5rem; font-weight:bold; color:#0d6efd; text-decoration:none;">MyBlog</a>
    
    <!-- Menu -->
    <ul style="list-style:none; margin:0; padding:0; display:flex; gap:15px; align-items:center;">
      <li><a href="/" style="text-decoration:none; color:#333; font-weight:500;">Home</a></li>
      <li><a href="/posts" style="text-decoration:none; color:#333; font-weight:500;">All Posts</a></li>

      <% if(userId){ %>
        <li><a href="/posts/create" style="text-decoration:none; color:#0d6efd; font-weight:bold;">Create Post</a></li>
        <li><a href="/logout" style="text-decoration:none; color:#dc3545; font-weight:bold;">Logout</a></li>
      <% } else { %>
        <li><a href="/login" style="text-decoration:none; color:#0d6efd; font-weight:bold;">Login</a></li>
        <li><a href="/register" style="text-decoration:none; color:#198754; font-weight:bold;">Register</a></li>
      <% } %>
    </ul>
  </div>
</nav>
<hr style="border:0; height:1px; background:#ddd; margin:0;">