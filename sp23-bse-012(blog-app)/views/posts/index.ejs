<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Blog Posts</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f4f4f9;
            font-family: Arial, sans-serif;
        }
        header {
            background-color: #343a40;
            color: white;
            padding: 20px 0;
            text-align: center;
        }
        header h1 {
            margin: 0;
            font-size: 2rem;
        }
        .container {
            margin-top: 30px;
        }
        .post-card {
            background-color: white;
            border-radius: 8px;
            box-shadow: 0 3px 8px rgba(0,0,0,0.1);
            padding: 20px;
            margin-bottom: 25px;
            transition: transform 0.2s;
        }
        .post-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        .post-image {
            max-width: 100%;
            border-radius: 5px;
            margin: 10px 0;
        }
        .post-meta {
            font-size: 0.9rem;
            color: #555;
        }
        .post-actions a {
            text-decoration: none;
            color: #007bff;
            margin-right: 10px;
        }
        .post-actions a:hover {
            text-decoration: underline;
        }
        .btn-custom {
            margin-bottom: 20px;
        }
        footer {
            text-align: center;
            padding: 15px 0;
            margin-top: 40px;
            color: #777;
            border-top: 1px solid #ddd;
        }
    </style>
</head>
<body>

<header>
    <h1>My Blog</h1>
</header>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a href="/posts/create" class="btn btn-primary btn-custom">Create New Post</a>
        <a href="/logout" class="btn btn-danger btn-custom">Logout</a>
    </div>

    <% if(posts.length === 0){ %>
        <div class="alert alert-info">No posts available. Start by creating a new post!</div>
    <% } %>

    <div class="row">
        <% posts.forEach(post => { %>
            <div class="col-md-6 col-lg-4">
                <div class="post-card">
                    <h3><%= post.title %></h3>
                    <p><%= post.content.length > 150 ? post.content.substring(0,150) + '...' : post.content %></p>

                    <% if(post.image){ %>
                        <img src="/uploads/<%= post.image %>" alt="Post Image" class="post-image">
                    <% } %>

                    <p class="post-meta">Author: <%= post.author ? post.author.username : "Unknown" %></p>

                    <div class="post-actions">
                        <a href="/posts/<%= post._id %>" class="btn btn-outline-secondary btn-sm">View</a>
                        <% if(userId && post.author && post.author._id.toString() === userId){ %>
                            <a href="/posts/edit/<%= post._id %>" class="btn btn-outline-primary btn-sm">Edit</a>
                            <a href="/posts/delete/<%= post._id %>" class="btn btn-outline-danger btn-sm">Delete</a>
                        <% } %>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<footer>
    &copy; <%= new Date().getFullYear() %> My Blog. All rights reserved.
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>